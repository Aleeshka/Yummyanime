@model AnimeCatalogViewModel
@{
string strTitle = "Каталог аниме";
ViewBag.Title = strTitle;
string safeSort = Model.Sort switch
{
"year_asc" => "year_asc",
"rating_desc" => "rating_desc",
"rating_asc" => "rating_asc",
_ => "year_desc"
};
}
<div class="col-12">
    <div id="content">
        <section class="anime-catalog-section glass-panel">
            <header class="catalog-header">
                <h2 class="icon fa-photo-video">@strTitle</h2>
            </header>
            <form method="get" asp-controller="Anime" asp-action="Index" class="anime-filter-bar glass-panel">
                <input type="text" name="search" value="@Model.Search" placeholder="Поиск по названию" />
                <select name="sort">
                    <option value="year_desc" selected="@(safeSort == "year_desc" ? "selected" : null)">Год: сначала новые</option>
                    <option value="year_asc" selected="@(safeSort == "year_asc" ? "selected" : null)">Год: сначала старые</option>
                    <option value="rating_desc" selected="@(safeSort == "rating_desc" ? "selected" : null)">Рейтинг: по убыванию</option>
                    <option value="rating_asc" selected="@(safeSort == "rating_asc" ? "selected" : null)">Рейтинг: по возрастанию</option>
                </select>
                <button type="submit" class="button">Применить</button>
            </form>

            @if (Model.Items.Any())
            {
                <div class="anime-poster-grid">
                    @foreach (AnimeDTO entity in Model.Items)
                    {
                        <article class="poster-card glass-panel">
                            <a asp-area="" asp-controller="Anime" asp-action="Show" asp-route-id="@entity.Id" class="poster-link">
                                <img src="@(string.IsNullOrWhiteSpace(entity.PhotoFileName) ? Url.Content("~/img/default-poster.svg") : Url.Content($"~/img/{entity.PhotoFileName}"))" alt="@entity.Title" loading="lazy" />
                                <div class="poster-overlay">
                                    <h3 title="@entity.Title">@entity.Title</h3>
                                </div>
                            </a>
                            <div class="poster-meta">
                                <span>@(string.IsNullOrWhiteSpace(entity.GenreName) ? "Без жанра" : entity.GenreName)</span>
                                <span>@entity.Year</span>
                                <span>★ @entity.Rating</span>
                            </div>
                        </article>
                    }
                </div>
            }
            else
            {
                <p>Ничего не найдено.</p>
            }

            @if (Model.TotalPages > 1)
            {
                <nav class="catalog-pagination glass-panel" aria-label="Пагинация каталога">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        if (i == Model.CurrentPage)
                        {
                            <span class="page-current">@i</span>
                        }
                        else
                        {
                            <a asp-controller="Anime" asp-action="Index" asp-route-page="@i" asp-route-sort="@safeSort" asp-route-search="@Model.Search" aria-label="Перейти на страницу @i">@i</a>
                        }
                    }
                </nav>
            }
        </section>
    </div>
</div>
