@model AnimeCatalogViewModel
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer L
@{
string strTitle = L["Catalog_Title"].Value;
ViewBag.Title = strTitle;
string safeSort = Model.Sort switch
{
"year_asc" => "year_asc",
"rating_desc" => "rating_desc",
"rating_asc" => "rating_asc",
_ => "year_desc"
};
}
<div class="col-12">
    <div id="content">
        <section class="anime-catalog-section glass-panel">
            <header class="catalog-header">
                <h2 class="icon fa-photo-video">@strTitle</h2>
            </header>
            <form method="get" asp-controller="Anime" asp-action="Index" class="anime-filter-bar glass-panel">
                <input type="text" name="search" value="@Model.Search" placeholder="@L["Search_Placeholder"]" />
                <select name="sort">
                    <option value="year_desc" selected="@(safeSort == "year_desc" ? "selected" : null)">@L["Sort_YearDesc"]</option>
                    <option value="year_asc" selected="@(safeSort == "year_asc" ? "selected" : null)">@L["Sort_YearAsc"]</option>
                    <option value="rating_desc" selected="@(safeSort == "rating_desc" ? "selected" : null)">@L["Sort_RatingDesc"]</option>
                    <option value="rating_asc" selected="@(safeSort == "rating_asc" ? "selected" : null)">@L["Sort_RatingAsc"]</option>
                </select>
                <button type="submit" class="button">@L["Apply_Button"]</button>
            </form>

            @if (Model.Items.Any())
            {
                <div class="anime-poster-grid">
                    @foreach (AnimeDTO entity in Model.Items)
                    {
                        <article class="poster-card glass-panel">
                            <a asp-area="" asp-controller="Anime" asp-action="Show" asp-route-id="@entity.Id" class="poster-link">
                                <img src="@(string.IsNullOrWhiteSpace(entity.PhotoFileName) ? Url.Content("~/img/poster-placeholder.svg") : Url.Content($"~/img/{entity.PhotoFileName}"))"
                                     alt="@entity.Title" loading="lazy"
                                     onerror="this.onerror=null;this.src='@Url.Content("~/img/poster-placeholder.svg")';" />
                                <div class="poster-overlay">
                                    <h3 title="@entity.Title">@entity.Title</h3>
                                </div>
                            </a>
                            <div class="poster-meta">
                                <span>@(string.IsNullOrWhiteSpace(entity.GenreName) ? L["NoGenre"] : entity.GenreName)</span>
                                <span>@entity.Year</span>
                                <span>★ @entity.Rating.ToString("0.00")</span>
                            </div>
                        </article>
                    }
                </div>
            }
            else
            {
                <p>@L["NothingFound"]</p>
            }

            @if (Model.TotalPages > 1)
            {
                <nav class="catalog-pagination glass-panel" aria-label="@L["Pagination_Aria"]">
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        if (i == Model.CurrentPage)
                        {
                            <span class="page-current">@i</span>
                        }
                        else
                        {
                            <a asp-controller="Anime" asp-action="Index" asp-route-page="@i" asp-route-sort="@safeSort" asp-route-search="@Model.Search" aria-label="@L["Pagination_GoToPage", i]">@i</a>
                        }
                    }
                </nav>
            }
        </section>
    </div>
</div>




<style>
.video-player {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 */
    height: 0;
    overflow: hidden;
    margin-bottom: 2rem;
    border-radius: 12px;
}

.video-player iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
}
</style>
