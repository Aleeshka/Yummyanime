@model AnimeDTO
@{
string? strTitle = Model.Title;
ViewBag.Title = strTitle;
string posterUrl = string.IsNullOrWhiteSpace(Model.PhotoFileName)
    ? Url.Content("~/img/default-poster.svg")
    : Url.Content($"~/img/{Model.PhotoFileName}");
}
<div class="col-12">
    <div id="content">
        <section class="anime-show-hero glass-panel" style="--hero-bg-image: url('@posterUrl')">
            <div class="anime-show-hero-inner">
                <p class="hero-kicker">Смотреть</p>
                <h2>@strTitle</h2>
                <p class="hero-short">@Model.DescriptionShort</p>
                <div class="hero-cta-row">
                    <a asp-area="" asp-controller="Anime" asp-action="Index" class="button">← В каталог</a>
                    <a asp-area="" asp-controller="Home" asp-action="Contacts" class="button alt">Связаться</a>
                </div>
            </div>
        </section>

        <section class="anime-show-layout">
            <aside class="anime-show-poster glass-panel">
                <img src="@posterUrl" class="img-block" alt="@Model.Title" />
            </aside>
            <article class="anime-show-details glass-panel">
                <h3>Детали</h3>
                <div class="anime-detail-line"><span>Жанр</span><strong>@(string.IsNullOrWhiteSpace(Model.GenreName) ? "Без жанра" : Model.GenreName)</strong></div>
                <div class="anime-detail-line"><span>Год</span><strong>@Model.Year</strong></div>
                <div class="anime-detail-line"><span>Рейтинг</span><strong>★ @Model.Rating</strong></div>
                <p>@Model.Description</p>
            </article>
        </section>
    </div>
</div>
