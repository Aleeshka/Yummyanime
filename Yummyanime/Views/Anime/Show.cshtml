@model AnimeDTO
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer L
@{
    ViewBag.Title = Model.Title;
    bool isFavorite = ViewBag.IsFavorite is bool value && value;
    string returnUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="col-12">
    <div id="content">
        @if (!string.IsNullOrEmpty(Model.VideoUrl))
        {
            <section class="anime-show-hero glass-panel">
                @if (Model.VideoUrl.Contains("kodikplayer.com"))
                {
                    <div class="video-player">
                        <iframe src="@Model.VideoUrl"
                                title="Kodik Player"
                                frameborder="0"
                                allowfullscreen
                                allow="autoplay; fullscreen; picture-in-picture; encrypted-media"
                                referrerpolicy="strict-origin-when-cross-origin">
                        </iframe>
                    </div>
                }
                else
                {
                    <div class="video-player">
                        <iframe src="@Model.VideoUrl"
                                title="YouTube Player"
                                frameborder="0"
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                allowfullscreen>
                        </iframe>
                    </div>
                }
            </section>
        }

        <section class="anime-show-layout glass-panel">
            <div class="anime-show-poster">
                <img src="@(string.IsNullOrWhiteSpace(Model.PhotoFileName) ? Url.Content("~/img/poster-placeholder.svg") : Url.Content($"~/img/{Model.PhotoFileName}"))"
                     alt="@Model.Title" />
            </div>
            <div class="anime-show-details">
                <h2>@Model.Title</h2>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <form asp-controller="Anime" asp-action="ToggleFavorite" method="post" style="margin-bottom: 1rem;">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                        <button type="submit" class="button">
                            @(isFavorite ? L["RemoveFromFavorites"] : L["AddToFavorites"])
                        </button>
                    </form>
                }
                else
                {
                    <p>
                        <a asp-controller="Account" asp-action="Login" asp-route-returnUrl="@returnUrl">@L["Login_Link"]</a>
                        @L["LoginToUseFavorites"]
                    </p>
                }

                <div class="anime-detail-line">
                    <span>@L["Genre_Label"]:</span>
                    <span>@(string.IsNullOrWhiteSpace(Model.GenreName) ? L["Genre_Empty"] : Model.GenreName)</span>
                </div>

                <div class="anime-detail-line">
                    <span>@L["Year_Label"]:</span>
                    <span>@Model.Year</span>
                </div>

                <div class="anime-detail-line">
                    <span>@L["Rating_Label"]:</span>
                    <span>★ @Model.Rating</span>
                </div>

                <div class="anime-detail-line">
                    <span>@L["Description_Label"]:</span>
                </div>
                <p>@(string.IsNullOrWhiteSpace(Model.Description) ? L["Description_Empty"] : Model.Description)</p>
            </div>
        </section>
    </div>
</div>

<style>
.anime-show-hero {
    position: relative;
    display: block;
    min-height: 0;
}

.anime-show-hero::before,
.anime-show-hero::after {
    pointer-events: none;
    z-index: 0;
}

.video-player {
    position: relative;
    z-index: 1;
    width: 100%;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    margin-bottom: 2rem;
    border-radius: 12px;
}

.video-player iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: auto;
}
</style>
