@model AnimeDTO
@{
    ViewBag.Title = Model.Title;
}

<div class="col-12">
    <div id="content">
        <!-- Плеер видео -->
        @if (!string.IsNullOrEmpty(Model.VideoUrl))
        {
            <section class="anime-show-hero glass-panel">
                @if (Model.VideoUrl.Contains("kodikplayer.com"))
                {
                    <!-- Kodik плеер -->
                    <div class="video-player">
                        <iframe src="@Model.VideoUrl" 
                                frameborder="0" 
                                AllowFullScreen 
                                allow="autoplay *; fullscreen *">
                        </iframe>
                    </div>
                }
                else
                {
                    <!-- YouTube плеер -->
                    <div class="video-player">
                        <iframe src="@Model.VideoUrl"  
                                frameborder="0" 
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                                allowfullscreen>
                        </iframe>
                    </div>
                }
            </section>
        }

        <!-- Информация об аниме -->
        <section class="anime-show-layout glass-panel">
            <div class="anime-show-poster">
                <img src="@(string.IsNullOrWhiteSpace(Model.PhotoFileName) ? Url.Content("~/img/poster-placeholder.svg") : Url.Content($"~/img/{Model.PhotoFileName}"))"
                     alt="@Model.Title" />
            </div>
            <div class="anime-show-details">
                <h2>@Model.Title</h2>
                <div class="anime-detail-line">
                    <span>Жанр:</span>
                    <span>@(string.IsNullOrWhiteSpace(Model.GenreName) ? "Не указан" : Model.GenreName)</span>
                </div>
                <div class="anime-detail-line">
                    <span>Год:</span>
                    <span>@Model.Year</span>
                </div>
                <div class="anime-detail-line">
                    <span>Рейтинг:</span>
                    <span>★ @Model.Rating</span>
                </div>
                <div class="anime-detail-line">
                    <span>Описание:</span>
                </div>
                <p>@Model.Description</p>
            </div>
        </section>
    </div>
</div>

<style>
.video-player {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%; /* 16:9 */
    height: 0;
    overflow: hidden;
    margin-bottom: 2rem;
    border-radius: 12px;
}

.video-player iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
}
</style>
