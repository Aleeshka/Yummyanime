@using System.Collections
@{
string strTitle = "Панель администратора";
ViewBag.Title = strTitle;
IEnumerable<Genre>? genres = ViewBag.Genres;
IEnumerable<Anime>? anime = ViewBag.Anime;
}
<div>
<h2>@strTitle</h2>
<div>
<h3>Жанры</h3>
<div class="div-box">
<a asp-area="" asp-controller="Admin" asp-action="GenresEdit" asp-route-id="">Добавить жанр</a>
</div>
@if (genres.Any())
{
<div>
@foreach (Genre entity in genres)
{
<div>
<a asp-area="" asp-controller="Admin" asp-action="GenresEdit" asp-route-id="@entity.Id">редактировать</a>
|
<form style="display: inline-block;" id="form-genre-@entity.Id" asp-area=""
      asp-controller="Admin" asp-action="GenresDelete" method="post">
<input type="hidden" name="id" value="@entity.Id"/>
<a href="#" onclick="document.getElementById('form-genre-@entity.Id').submit();">удалить</a>
</form>
|
<span>@entity.Title</span>
</div>
}
</div>
}
</div>
<div>
<h3>Аниме</h3>
<div class="div-box">
<a asp-area="" asp-controller="Admin" asp-action="AnimeEdit" asp-route-id="">Добавить аниме</a>
</div>

@if (anime.Any())
{
<div>
@foreach (Anime entity in anime)
{
<div>
<a asp-area="" asp-controller="Admin" asp-action="AnimeEdit" asp-route-id="@entity.Id">редактировать</a>
|
<form style="display: inline-block;" id="form-anime-@entity.Id" asp-area=""
      asp-controller="Admin" asp-action="AnimeDelete" method="post">
<input type="hidden" name="id" value="@entity.Id" />
<a href="#" onclick="document.getElementById('form-anime-@entity.Id').submit();">удалить</a>
</form>
|
<span>
@entity.Genre?.Title
|
<a asp-area="" asp-controller="Anime" asp-action="Show" asp-route-id="@entity.Id">@entity.Title</a>
</span>
</div>
}
</div>
}
</div>

<div class="div-box">
<form asp-area="" asp-controller="Account" asp-action="Logout" method="post">
<input type="submit" value="Выйти" />
</form>
</div>
</div>
