@inject IConfiguration config
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer L
@{
AppConfig? appConfig = config.GetSection("Project").Get<AppConfig>();
IEnumerable<AnimeDTO> topRated = ViewBag.TopRated as IEnumerable<AnimeDTO> ?? Enumerable.Empty<AnimeDTO>();
IEnumerable<AnimeDTO> latest = ViewBag.Latest as IEnumerable<AnimeDTO> ?? Enumerable.Empty<AnimeDTO>();
IEnumerable<AnimeDTO> homeShowcase = topRated.Any() ? topRated : latest;
AnimeDTO? featured = homeShowcase.FirstOrDefault();
string featuredPoster = featured is null || string.IsNullOrWhiteSpace(featured.PhotoFileName)
    ? Url.Content("~/img/default-poster.svg")
    : Url.Content($"~/img/{featured.PhotoFileName}");
bool hasRandomCandidate = homeShowcase.Any();
}
<div class="col-12">
<div id="content">
<section class="portal-hero glass-panel" style="--portal-hero-image: url('@featuredPoster')">
    <div class="portal-hero-content">
        <p class="hero-kicker">@L["Hero_Kicker"]</p>
        <h2>@L["Hero_Title", appConfig?.Company.CompanyName ?? "YummyAnime"]</h2>
        <p>@L["Hero_Description"]</p>
        <form method="get" asp-controller="Anime" asp-action="Index" class="portal-search-form">
            <input type="text" name="search" placeholder="@L["Search_Placeholder"]" />
            <button type="submit" class="button">@L["Search_Button"]</button>
        </form>
        <div class="hero-actions">
            <a asp-area="" asp-controller="Anime" asp-action="Index" class="button">@L["GoToCatalog_Button"]</a>
            <button type="button" class="button alt js-random-top" disabled="@(!hasRandomCandidate)">@L["Random_Button"]</button>
        </div>
    </div>
</section>

<section class="portal-section">
    <header class="major">
        <h2>@L["TopRated_Title"]</h2>
    </header>
    <div class="top-rated-strip">
        @foreach (AnimeDTO entity in homeShowcase)
        {
            <a asp-area="" asp-controller="Anime" asp-action="Show" asp-route-id="@entity.Id" class="top-rated-card glass-panel" data-random-url="@Url.Action("Show", "Anime", new { id = entity.Id })">
                <img src="@(string.IsNullOrWhiteSpace(entity.PhotoFileName) ? Url.Content("~/img/default-poster.svg") : Url.Content($"~/img/{entity.PhotoFileName}"))" alt="@entity.Title" loading="lazy" />
                <span class="title">@entity.Title</span>
                <span class="rating">★ @entity.Rating.ToString("0.00")</span>
            </a>
        }
    </div>
</section>

<section class="portal-grid">
    <article class="portal-card">
        <header class="major"><h3>@L["Updates_Title"]</h3></header>
        @if (latest.Any())
        {
            <ul>
                @foreach (AnimeDTO entity in latest)
                {
                    <li>
                        <a asp-area="" asp-controller="Anime" asp-action="Show" asp-route-id="@entity.Id">@entity.Title</a>
                        <span>(@entity.Year)</span>
                    </li>
                }
            </ul>
        }
        else
        {
            <p>@L["Updates_Empty"]</p>
        }
    </article>

    <article class="portal-card">
        <header class="major"><h3>@L["News_Title"]</h3></header>
        <ul>
            <li>@L["News_1"]</li>
            <li>@L["News_2"]</li>
            <li>@L["News_3"]</li>
        </ul>
    </article>

    <article class="portal-card">
        <header class="major"><h3>@L["Announcements_Title"]</h3></header>
        <ul>
            <li>@L["Announcements_1"]</li>
            <li>@L["Announcements_2"]</li>
            <li>@L["Announcements_3"]</li>
        </ul>
    </article>
</section>
</div>
</div>
<script>
    (function () {
        const button = document.querySelector('.js-random-top');
        if (!button || button.disabled) return;
        button.addEventListener('click', function () {
            const cards = Array.from(document.querySelectorAll('.top-rated-card[data-random-url]'));
            if (!cards.length) {
                window.location.href = '@Url.Action("Index", "Anime")';
                return;
            }
            const randomCard = cards[Math.floor(Math.random() * cards.length)];
            const randomUrl = randomCard.getAttribute('data-random-url');
            if (randomUrl) {
                window.location.href = randomUrl;
            }
        });
    })();
</script>
