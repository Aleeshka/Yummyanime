@model HomeIndexViewModel
@inject IConfiguration config
@{
    AppConfig? appConfig = config.GetSection("Project").Get<AppConfig>();
}

<div class="col-12">
    <section class="home-hero">
        <div class="home-hero__content">
            <p class="home-hero__label">Yummyanime Portal</p>
            <h2>Добро пожаловать в @appConfig?.Company.CompanyName</h2>
            <p>Открывай топовые тайтлы, следи за обновлениями и переходи в полный каталог аниме.</p>
            <form method="get" asp-controller="Anime" asp-action="Index" class="home-search">
                <input type="text" name="search" placeholder="Поиск аниме по названию..." />
                <input type="submit" value="Искать" />
            </form>
        </div>
    </section>

    <section class="home-top-strip">
        <header class="major">
            <h2>Топ аниме</h2>
        </header>
        <div class="home-top-strip__items">
            @foreach (AnimeDTO entity in Model.TopAnime)
            {
                string posterFileName = string.IsNullOrWhiteSpace(entity.PhotoFileName)
                    ? "bg001.jpg"
                    : System.IO.Path.GetFileName(entity.PhotoFileName);
                if (string.IsNullOrWhiteSpace(posterFileName))
                {
                    posterFileName = "bg001.jpg";
                }

                <article class="home-top-card">
                    <a asp-controller="Anime" asp-action="Show" asp-route-id="@entity.Id" class="home-top-card__poster">
                        <img src="@Url.Content($"~/img/{posterFileName}")" alt="@entity.Title" />
                    </a>
                    <div class="home-top-card__body">
                        <a asp-controller="Anime" asp-action="Show" asp-route-id="@entity.Id" class="home-top-card__title">@entity.Title</a>
                        <span class="home-top-card__rating">Рейтинг: @entity.Rating</span>
                    </div>
                </article>
            }
        </div>
    </section>

    <section class="home-portal-grid">
        <article class="home-portal-block">
            <h3>Обновления</h3>
            <ul>
                @foreach (AnimeDTO entity in Model.Updates)
                {
                    <li>
                        <a asp-controller="Anime" asp-action="Show" asp-route-id="@entity.Id">@entity.Title</a>
                        <span>@entity.Year</span>
                    </li>
                }
            </ul>
        </article>

        <article class="home-portal-block">
            <h3>Новости</h3>
            <ul>
                <li><strong>Весенний сезон: что посмотреть в первую очередь</strong><span>Сегодня</span></li>
                <li><strong>Обновили подборки по жанрам и рейтингам</strong><span>Вчера</span></li>
                <li><strong>Новые карточки тайтлов уже в каталоге</strong><span>2 дня назад</span></li>
            </ul>
        </article>

        <article class="home-portal-block">
            <h3>Расписание</h3>
            <ul>
                <li><strong>Понедельник: новые серии экшен-тайтлов</strong><span>19:00</span></li>
                <li><strong>Среда: обновление романтики и драмы</strong><span>20:00</span></li>
                <li><strong>Пятница: подборка недели в топе</strong><span>21:00</span></li>
            </ul>
        </article>
    </section>
</div>
