@{
	bool isHomeIndex =
		string.Equals(ViewContext.RouteData.Values["controller"]?.ToString(), "Home", StringComparison.OrdinalIgnoreCase)
		&& string.Equals(ViewContext.RouteData.Values["action"]?.ToString(), "Index", StringComparison.OrdinalIgnoreCase);
	string bodyClass = isHomeIndex ? "is-preload theme-dark home-portal-page" : "left-sidebar is-preload theme-dark";
}
<!DOCTYPE HTML>
<html>
<head>
	@await Html.PartialAsync("_MetaPartial")
	@await Html.PartialAsync("_CssPartial")
</head>
<body class="@bodyClass">
	<div id="page-wrapper">
		@await Html.PartialAsync("_HeaderPartial")
		<div id="main-wrapper">
			<div class="wrapper style2">
				<div class="inner">
					<div class="container">
						<div class="row">
							@RenderBody()
						</div>
					</div>
				</div>
			</div>
		</div>
		@await Html.PartialAsync("_FooterPartial")
	</div>

@await Html.PartialAsync("_ScriptPartial")
</body>
</html>
